{
  // Routeur cloud - écoute les connexions des robots
  "mode": "router",
  "listen": {
    "endpoints": ["tcp/0.0.0.0:7447"]
  },
  "plugins": {
    "ros2dds": {
      "ros_distro": "jazzy"
    },
    // API REST pour lire les topics ROS 2 depuis le web
    "rest": {
      "http_port": 8000
    }
  }
}
